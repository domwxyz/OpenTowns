* text=auto

# Sources and data
# LF in the repo and in the working tree
*.java         text eol=lf
*.xml          text eol=lf
*.ini          text eol=lf
*.md           text eol=lf
*.gradle       text eol=lf
*.properties   text eol=lf
gradlew        text eol=lf
*.sh           text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
LICENSE        text eol=lf
CHANGELOG.md   text eol=lf

# Windows batch scripts need CRLF on checkout
# (cmd.exe can mis-parse labels in LF-only batch files)
*.bat          text eol=crlf

# Binaries
# Never normalize or diff
*.jar          binary
*.zip          binary
*.png          binary
*.ogg          binary
*.wav          binary
*.dll          binary
